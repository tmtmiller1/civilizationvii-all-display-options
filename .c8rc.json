{
  "all": true,
  "src": ["ui"],
  "include": ["ui/**/*.js"],
  "exclude": ["tests/**", "**/*.d.ts"],
  "reporter": ["text", "text-summary", "json-summary"],
  "report-dir": "coverage",
  "clean": true,
  "skip-full": false,
  "check-coverage": true,
  "branches": 100,
  "functions": 100,
  "lines": 100,
  "statements": 100
}
